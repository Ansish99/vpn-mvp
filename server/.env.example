# Central API
PORT=4000
JWT_SECRET=change-me-to-a-long-random-string
DB_PATH=./data/app.db

# Shared secret used to authenticate central API -> per-server wg-agent calls
AGENT_SHARED_SECRET=change-me-to-a-long-random-string

# wg-agent (runs on each VPN box, see src/wg/agentServer.ts)
AGENT_PORT=5000
WG_INTERFACE=wg0
